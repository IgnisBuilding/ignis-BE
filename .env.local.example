# Local backend example (constant/mock sensor stream)
PORT=4000
NEST_LOG_LEVELS=warn,error

# Database
DATABASE_URL=postgresql://user:password@host:5432/db

# Arduino mock stream for constant local readings
ARDUINO_MODE=mock
ARDUINO_MOCK_INTERVAL_MS=1000
ARDUINO_AUTO_DETECT_PORTS=false
ARDUINO_COM_PORT=COM5

# Thresholds
MQ7_WARNING_THRESHOLD=300
MQ7_ALERT_THRESHOLD=600
MQ5_WARNING_THRESHOLD=350
MQ5_ALERT_THRESHOLD=700

# Optional trigger target
# FIRE_DETECT_TRIGGER_URL=http://localhost:8091/
FIRE_DETECT_MAX_CAPTURE_SECONDS=10
# FIRE_DETECT_TRIGGER_API_KEY=

# Logging noise controls
DB_LOGGING=false
SENSOR_READING_DEBUG_LOGS=false
WS_DEBUG_LOGS=false
WS_LIFECYCLE_LOGS=false
ARDUINO_DEBUG=false
FIRE_SAFETY_DEBUG_LOGS=false
SENSOR_LOG_DEBUG=false

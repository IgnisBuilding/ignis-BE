{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/fireSafety/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "webpackConfigPath": "webpack.config.js",
    "tsConfigPath": "apps/fireSafety/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/fireSafety",
  "projects": {
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "billing": {
      "type": "application",
      "root": "apps/billing",
      "entryFile": "main",
      "sourceRoot": "apps/billing/src",
      "compilerOptions": {
        "tsConfigPath": "apps/billing/tsconfig.app.json"
      }
    },
    "community": {
      "type": "application",
      "root": "apps/community",
      "entryFile": "main",
      "sourceRoot": "apps/community/src",
      "compilerOptions": {
        "tsConfigPath": "apps/community/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "fireSafety": {
      "type": "application",
      "root": "apps/fireSafety",
      "entryFile": "main",
      "sourceRoot": "apps/fireSafety/src",
      "compilerOptions": {
        "tsConfigPath": "apps/fireSafety/tsconfig.app.json"
      }
    },
    "ignis-be": {
      "type": "application",
      "root": "apps/ignis-be",
      "entryFile": "main",
      "sourceRoot": "apps/ignis-be/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ignis-be/tsconfig.app.json"
      }
    },
    "metering": {
      "type": "application",
      "root": "apps/metering",
      "entryFile": "main",
      "sourceRoot": "apps/metering/src",
      "compilerOptions": {
        "tsConfigPath": "apps/metering/tsconfig.app.json"
      }
    },
    "notifications": {
      "type": "application",
      "root": "apps/notifications",
      "entryFile": "main",
      "sourceRoot": "apps/notifications/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notifications/tsconfig.app.json"
      }
    },
    "society-management": {
      "type": "application",
      "root": "apps/society-management",
      "entryFile": "main",
      "sourceRoot": "apps/society-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/society-management/tsconfig.app.json"
      }
    }
  }
}
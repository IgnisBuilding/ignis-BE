{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/ignis-be/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/ignis-be/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/ignis-be",
  "projects": {
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "ignis-be": {
      "type": "application",
      "root": "apps/ignis-be",
      "entryFile": "main",
      "sourceRoot": "apps/ignis-be/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ignis-be/tsconfig.app.json"
      }
    },
    "society-management": {
      "type": "application",
      "root": "apps/society-management",
      "entryFile": "main",
      "sourceRoot": "apps/society-management/src",
      "compilerOptions": {
        "tsConfigPath": "apps/society-management/tsconfig.app.json"
      }
    }
  }
}
# Render deployment env for ignis-be
PORT=4000
NEST_LOG_LEVELS=warn,error

# Database
DATABASE_URL=postgresql://user:password@host:5432/db

# Cloud runtime: no direct USB/COM access
ARDUINO_MODE=off
ARDUINO_AUTO_DETECT_PORTS=false

# Fire-detect trigger config
FIRE_DETECT_TRIGGER_URL=https://your-orchestrator-endpoint.example.com/trigger
FIRE_DETECT_MAX_CAPTURE_SECONDS=10
# FIRE_DETECT_TRIGGER_API_KEY=your-api-key

# Optional sensor-camera confirmation window (seconds)
SENSOR_CAMERA_CONFIRM_WINDOW_SECONDS=120

# Logging noise controls
DB_LOGGING=false
SENSOR_READING_DEBUG_LOGS=false
WS_DEBUG_LOGS=false
WS_LIFECYCLE_LOGS=false
ARDUINO_DEBUG=false
FIRE_SAFETY_DEBUG_LOGS=false
SENSOR_LOG_DEBUG=false
